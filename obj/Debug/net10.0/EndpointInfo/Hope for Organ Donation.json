          "bloodType": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "selectedOrgans": {
            "type": "string",
            "nullable": true
          },
          "birthDate": {
            "type": "string",
