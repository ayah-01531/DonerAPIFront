            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "selectedOrgans": {
            "type": "string",
            "nullable": true
          },
          "birthDate": {
            "type": "string",
            "nullable": true
          },
          "nationalIDNumber": {
            "type": "string",
            "nullable": true
          },
          "medicalReportUrl": {
            "type": "string",
            "nullable": true
          },
          "hasSignedConsent": {
            "type": "boolean",
            "nullable": true
